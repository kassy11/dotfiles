[user]
	name = kassy11
	email = kotaro11kassy@gmail.com
[alias]
	st = status
	co = checkout
	br = branch
	di = diff
	dic = diff --cached
	tr = log --graph --pretty='format:%C(yellow)%h%Creset %s %Cgreen(%an)%Creset %Cred%d%Creset'
	c = commit
	com = commit -m
	p = push
	pu = pull

[core]
	editor = vim -c \"set fenc=utf-8\"
	excludesfile = /Users/kotarokashihara/.gitignore_global
	autoCRLF = false
	quotepath = false
	pager = LESSCHARSET=utf-8 less
[color]
	ui = true
[filesystem "AdoptOpenJDK|11.0.4|/dev/disk1s1"]
	timestampResolution = 7000 nanoseconds
	minRacyThreshold = 0 nanoseconds
[filesystem "AdoptOpenJDK|11.0.4|/dev/disk1s5"]
	timestampResolution = 7000 nanoseconds
	minRacyThreshold = 0 nanoseconds
[commit]
	template = /Users/kotarokashihara/gitemoji/.commit_template
[credential]
	helper = osxkeychain
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[ghq]
	config = /Users/kotarokashihara/go/1.14.4/src
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
