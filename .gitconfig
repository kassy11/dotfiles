[user]
	name = kassy11
	email = kotaro11kassy@gmail.com
[alias]
	st = status --short --branch
	co = checkout
	br = branch
	di = diff
	dic = diff --cached
	tr = log --graph --pretty='format:%C(yellow)%h%Creset %s %Cgreen(%an)%Creset %Cred%d%Creset'
	c = commit
	com = commit -m
	p = push
	pu = pull
  glog = log --all --graph --date=short --decorate=short --pretty=format:'%Cgreen%h %Creset%cd %Cblue%cn %Creset%s'
[core]
	editor = nvim
	excludesfile = /Users/kotarokashihara/dotfiles/.gitignore_global
	autoCRLF = false
	quotepath = false
	pager = LESSCHARSET=utf-8 less
[color]
	ui = true
[filesystem "AdoptOpenJDK|11.0.4|/dev/disk1s1"]
	timestampResolution = 7000 nanoseconds
	minRacyThreshold = 0 nanoseconds
[filesystem "AdoptOpenJDK|11.0.4|/dev/disk1s5"]
	timestampResolution = 7000 nanoseconds
	minRacyThreshold = 0 nanoseconds
[commit]
	template = /Users/kotarokashihara/.commit_template
[credential]
	helper = osxkeychain
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[ghq]
	root = ~/dev
  user = kassy11
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[grep]
	lineNumber = true
[fetch]
	prune = true
